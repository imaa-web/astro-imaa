---
import PageBuilder from "@/components/common/pagebuilder/PageBuilder.astro";
import PortableTextRenderer from "@/components/common/PortableTextRenderer.astro";
import Container from "@/components/layout/Container.astro";
import PageSection from "@/components/layout/PageSection.astro";
import PageHero from "@/components/sections/PageHero.astro";
import Layout from "@/layouts/Layout.astro";
import { DEFAULT_TITLE } from "@/lib/constants";
import { loadQuery } from "@/lib/load-query";
import { ALL_PAGES_QUERY } from "@/lib/queries/page";
import { type ALL_PAGES_QUERY_RESULT } from "@/lib/sanity.types";
import { truncateExcerpt } from "@/lib/utils/string-utils";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const { data: pages } = await loadQuery<ALL_PAGES_QUERY_RESULT>({
    query: ALL_PAGES_QUERY,
  });

  return (pages ?? [])
    .filter((page) => page.slug != null)
    .map((page) => ({
      params: { slug: page.slug! },
      props: { page },
    }));
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={page.title ?? DEFAULT_TITLE} description={truncateExcerpt(page.excerpt ?? page.autoExcerpt)}>
  <PageHero heading={page.hero?.heading ?? page.title ?? DEFAULT_TITLE} tagline={page.hero?.tagline} />
  <PageSection>
    <Container size="md" class="mb-12">
      <PortableTextRenderer value={page.content} />
      <PageBuilder pageBuilder={page.pageBuilder} />
    </Container>
  </PageSection>
</Layout>
