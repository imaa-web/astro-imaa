---
import PageBuilder from "@/components/common/pagebuilder/PageBuilder.astro";
import FeaturedImage from "@/components/sections/FeaturedImage.astro";
import PageHero from "@/components/sections/PageHero.astro";
import UnderConstruction from "@/components/sections/UnderConstruction.astro";
import Layout from "@/layouts/Layout.astro";
import { DEFAULT_TITLE } from "@/lib/constants";
import { loadQuery } from "@/lib/load-query";
import { PAGE_BY_SLUG_QUERY } from "@/lib/queries/page";
import type { ALL_PAGES_QUERY_RESULT } from "@/lib/sanity.types";

type PageBySlugResult = ALL_PAGES_QUERY_RESULT[number] | null;

const { slug } = Astro.params;

const { data: page } = await loadQuery<PageBySlugResult>({
  query: PAGE_BY_SLUG_QUERY,
  params: { slug },
});

if (!page) return Astro.rewrite("/404");
---

<Layout title={page.title ?? DEFAULT_TITLE} description={page.excerpt ?? ""} image={page.featuredImage}>
  <PageHero heading={page.hero?.heading ?? page.title ?? DEFAULT_TITLE} tagline={page.hero?.tagline} />
  {
    slug?.includes("projetos") || slug?.includes("galeria") ? (
      <UnderConstruction />
    ) : (
      <>
        <FeaturedImage image={page.featuredImage} />
        <PageBuilder pageBuilder={page.pageBuilder} />
      </>
    )
  }
</Layout>
