---
import PageBuilder from "@/components/common/pagebuilder/PageBuilder.astro";
import PortableTextRenderer from "@/components/common/PortableTextRenderer.astro";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { ALL_PAGES_QUERY } from "@/lib/queries";
import { type ALL_PAGES_QUERY_RESULT } from "@/lib/sanity.types";
import type { GetStaticPaths } from "astro";
import galeria4 from "../assets/galeria-4.jpg";

export const getStaticPaths = (async () => {
  const { data: pages } = await loadQuery<ALL_PAGES_QUERY_RESULT>({
    query: ALL_PAGES_QUERY,
  });

  return (pages ?? [])
    .filter((page) => page.slug != null)
    .map((page) => ({
      params: { slug: page.slug! },
      props: { page },
    }));
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={page.title ?? ""} description={page.excerpt ?? ""}>
  {
    page.title && (
      <div style={`background-image: url(${galeria4.src})`} class="bg-no-repeat bg-center bg-cover">
        <div class="bg-primary/80 py-20">
          <h1 class="text-4xl md:text-5xl font-bold text-center text-primary-foreground">{page.title}</h1>
        </div>
      </div>
    )
  }

  <section class="container mx-auto py-16 max-w-3xl">
    <PortableTextRenderer value={page.content} />
    <PageBuilder pageBuilder={page.pageBuilder} />
  </section>
</Layout>
