---
import PageBuilder from "@/components/common/pagebuilder/PageBuilder.astro";
import TransparencySectionCard from "@/components/features/transparency/TransparencySectionCard.astro";
import Container from "@/components/layout/Container.astro";
import PageSection from "@/components/layout/PageSection.astro";
import PageHero from "@/components/sections/PageHero.astro";
import { buttonVariants } from "@/components/ui/button";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { ALL_TRANSPARENCY_SECTIONS_QUERY, TRANSPARENCY_INDEX_PAGE_QUERY } from "@/lib/queries/transparency";
import type { ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT, TRANSPARENCY_INDEX_PAGE_QUERY_RESULT } from "@/lib/sanity.types";
import { cn } from "@/lib/utils/ui-utils";
import { ExternalLink } from "@lucide/astro";

const [{ data: page }, { data: sections }] = await Promise.all([
  loadQuery<TRANSPARENCY_INDEX_PAGE_QUERY_RESULT>({ query: TRANSPARENCY_INDEX_PAGE_QUERY }),
  loadQuery<ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT>({ query: ALL_TRANSPARENCY_SECTIONS_QUERY }),
]);

const validSections = (sections ?? []).filter((s) => s.slug);
---

<Layout title={page?.title ?? "Portal da Transparência"} description={page?.excerpt ?? ""} image={page?.featuredImage}>
  <PageHero
    heading={page?.hero?.heading ?? page?.title ?? "Portal da Transparência"}
    tagline={page?.hero?.tagline}
    containerSize="lg"
  />
  {page?.pageBuilder && page.pageBuilder.length > 0 && <PageBuilder pageBuilder={page.pageBuilder} />}

  <PageSection py="md" class="pt-0">
    <Container size="lg">
      <div class="space-y-2 mb-4">
        <p class="heading-label-on-light">ACESSO À INFORMAÇÃO</p>
        <h3 class="heading-2">Nossos parceiros institucionais</h3>
        <p class="body-text text-pretty">Selecione a área desejada:</p>
      </div>

      {
        validSections.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {validSections.map((section) => (
              <TransparencySectionCard section={section} />
            ))}
          </div>
        ) : (
          <p class="text-center text-muted-foreground font-sans">Nenhuma seção cadastrada ainda.</p>
        )
      }

      <div class="mt-12 text-center">
        <a
          href="https://portaldatransparencia.gov.br"
          target="_blank"
          rel="noopener noreferrer"
          class={cn(
            buttonVariants({ variant: "outline" }),
            "border-primary text-primary hover:bg-primary hover:text-white max-w-full h-auto whitespace-normal py-2 text-pretty",
          )}
        >
          Portal da Transparência do Governo Federal
          <ExternalLink class="w-4 h-4 shrink-0" aria-hidden="true" />
          <span class="sr-only">(abre em nova aba)</span>
        </a>
      </div>
    </Container>
  </PageSection>
</Layout>
