---
import HeroSection from "@/components/features/home/HeroSection";
import MissionSection from "@/components/features/home/MissionSection.astro";
import ProjectsPreviewSection from "@/components/features/home/ProjectsPreviewSection.astro";
import SocialSection from "@/components/features/home/SocialSection.astro";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { HOME_PAGE_QUERY } from "@/lib/queries/home";
import type { HomePageQuery, QuerySocialLinkWithImage } from "@/lib/sanity-derived-types";

const { data: homePage } = await loadQuery<HomePageQuery>({ query: HOME_PAGE_QUERY });

const { siteSettings } = Astro.locals;

const logo = homePage?.logo ?? siteSettings?.logo ?? null;
const socialLinks: QuerySocialLinkWithImage[] = (siteSettings?.socialLinks ?? []).filter((s): s is QuerySocialLinkWithImage => s.platform != null && s.url != null);
---

<Layout title={homePage?.title ?? "Início"} description={homePage?.excerpt ?? siteSettings?.defaultSeoDescription ?? ""}>
    <HeroSection
        client:load
        description={homePage?.heroDescription ?? null}
        logo={logo}
        primaryCta={homePage?.primaryCta ?? null}
        secondaryCta={homePage?.secondaryCta ?? null}
        blockHighlight={homePage?.blockHighlightSection ?? null}
    />
    <MissionSection section={homePage?.missionSection ?? null} />
    <ProjectsPreviewSection section={homePage?.projectsPreview ?? null} />
    <SocialSection socialLinks={socialLinks} />
</Layout>
