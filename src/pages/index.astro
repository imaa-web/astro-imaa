---
import HeroSection from "@/components/features/home/HeroSection";
import MissionSection from "@/components/features/home/MissionSection.astro";
import ProjectsPreviewSection from "@/components/features/home/ProjectsPreviewSection.astro";
import SocialSection from "@/components/features/home/SocialSection.astro";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { HOME_PAGE_QUERY } from "@/lib/queries/home";
import { getEntry } from "astro:content";
import type { QuerySocialLinkWithImage } from "@/lib/sanity-derived-types";
import type { HOME_PAGE_QUERY_RESULT } from "@/lib/sanity.types";

const [{ data: homePage }, siteSettings] = await Promise.all([
  loadQuery<HOME_PAGE_QUERY_RESULT>({ query: HOME_PAGE_QUERY }),
  getEntry("siteSettings", "site-settings"),
]);

const logo = homePage?.logo ?? siteSettings?.data.logo ?? null;
const socialLinks: QuerySocialLinkWithImage[] = (siteSettings?.data.socialLinks ?? []).filter(
  (s): s is QuerySocialLinkWithImage => s.platform != null && s.url != null,
);
---

<Layout
  title={homePage?.title ?? "Início"}
  description={homePage?.excerpt ?? siteSettings?.data.defaultSeoDescription ?? ""}
>
  <HeroSection
    client:load
    description={homePage?.heroDescription ?? null}
    logo={logo}
    primaryCta={homePage?.primaryCta ?? null}
    secondaryCta={homePage?.secondaryCta ?? null}
    blockHighlight={homePage?.blockHighlightSection ?? null}
  />
  <MissionSection section={homePage?.missionSection ?? null} />
  <ProjectsPreviewSection section={homePage?.projectsPreview ?? null} />
  <SocialSection socialLinks={socialLinks} />
</Layout>

<script>
  import confetti from "canvas-confetti";

  confetti({
    particleCount: 150,
    spread: 160,
    origin: { y: 0 },
    gravity: 0.5,
    ticks: 400,
  });
</script>
