---
import HeroSection from "@/components/features/home/HeroSection";
import Layout from "@/layouts/Layout.astro";
import { loadQuery } from "@/lib/load-query";
import { HOME_PAGE_QUERY } from "@/lib/queries/home";
import { getEntry } from "astro:content";
import type { HOME_PAGE_QUERY_RESULT } from "@/lib/sanity.types";
import UnderConstruction from "@/components/sections/UnderConstruction.astro";

const siteSettings = await getEntry("siteSettings", "site-settings");

const { data: homePage } = await loadQuery<HOME_PAGE_QUERY_RESULT>({
  query: HOME_PAGE_QUERY,
});

const logo = homePage?.logo ?? siteSettings?.data.logo ?? null;
---

<Layout
  title={homePage?.title ?? "Início"}
  description={homePage?.excerpt ?? siteSettings?.data.defaultSeoDescription ?? ""}
>
  <HeroSection
    client:load
    description={homePage?.heroDescription ?? null}
    logo={logo}
    primaryCta={homePage?.primaryCta ?? null}
    secondaryCta={homePage?.secondaryCta ?? null}
  />
  <UnderConstruction />
</Layout>

<script>
  import confetti from "canvas-confetti";

  confetti({
    particleCount: 150,
    spread: 160,
    origin: { y: 0 },
    gravity: 0.5,
    ticks: 300,
  });
</script>
