---
import SanityImage from "@/components/common/SanityImage";
import Container from "@/components/layout/Container.astro";
import type { SanityImageBase } from "@/lib/sanity-derived-types";

interface Props {
  image?: (SanityImageBase & { showInPage?: boolean | null }) | null;
}

const { image } = Astro.props;

const shouldRender = image?.showInPage && image?.asset;
---

{
  shouldRender && (
    <Container size="lg" class="pt-pagebuilder">
      <div class="rounded-2xl overflow-hidden shadow-lg aspect-video">
        <SanityImage
          client:load
          image={image}
          width={900}
          height={506}
          sizes="(max-width: 768px) 100vw, 992px"
          className="w-full h-full object-cover"
        />
      </div>
    </Container>
  )
}
