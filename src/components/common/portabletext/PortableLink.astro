---
import { resolveSafeHref } from "@/lib/utils/link-utils";

interface MarkDef {
  href?: string;
  blank?: boolean;
}

interface Props {
  node: {
    markDef?: MarkDef;
  };
}

const { node } = Astro.props;

const markDef = node?.markDef;
const safeHref = resolveSafeHref(markDef?.href ?? "");

// http:// is intentionally excluded from SAFE_SCHEMES in resolveSafeHref,
// so only https:// can reach this point as an external link.
const isExternal = (markDef?.href ?? "").startsWith("https://");
const shouldOpenInNewTab = markDef?.blank !== undefined ? markDef.blank : isExternal;
---

{
  safeHref === null ? (
    <slot />
  ) : safeHref ? (
    <a
      href={safeHref}
      target={shouldOpenInNewTab ? "_blank" : undefined}
      rel={shouldOpenInNewTab || isExternal ? "noopener noreferrer" : undefined}
      class="font-medium text-accent underline decoration-accent/40 underline-offset-4 hover:decoration-accent transition-all"
    >
      <slot />
    </a>
  ) : (
    <span class="text-red-500 line-through cursor-not-allowed" title="Link inseguro bloqueado">
      <slot />
    </span>
  )
}
