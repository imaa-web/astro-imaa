---
import { resolveCta } from "@/lib/utils/link-utils";
import { ArrowRight, ExternalLink } from "@lucide/astro";

interface CtaData {
  label?: string | null;
  linkType?: string | null;
  slug?: string | null;
  externalUrl?: string | null;
  openInNewTab?: boolean | null;
}

interface ShowcaseItem {
  _key: string;
  name?: string | null;
  description?: string | null;
  cta?: CtaData | null;
}

interface Props {
  node: {
    heading?: string | null;
    subtitle?: string | null;
    items?: ShowcaseItem[] | null;
  };
}

const { node } = Astro.props;
const { heading, subtitle, items } = node;
---

{
  items && items.length > 0 && (
    <div class="my-10">
      {heading && <h3>{heading}</h3>}
      {subtitle && <p class="text-base leading-relaxed mb-5">{subtitle}</p>}

      <div
        class="not-prose border border-border rounded-xl overflow-hidden space-y-4 sm:space-y-0"
        role="table"
        aria-label={heading || "Vitrine de Projetos"}
      >
        {/* Header - hidden on mobile */}
        <div
          class="hidden sm:flex bg-primary text-primary-foreground text-sm font-semibold uppercase tracking-wide"
          role="row"
        >
          <span class="w-70 shrink-0 px-5 py-3" role="columnheader">
            Projeto
          </span>
          <span class="flex-1 px-5 py-3 border-l border-primary-foreground/20" role="columnheader">
            O que fazemos pela comunidade
          </span>
        </div>

        {items.map((item) => {
          const resolved = item.cta?.label ? resolveCta(item.cta) : null;

          return (
            <div
              class="flex flex-col sm:flex-row border-t border-border bg-card transition-colors hover:bg-muted"
              role="row"
            >
              <div
                class="sm:w-70 sm:shrink-0 px-5 py-3 sm:py-4 flex items-center bg-primary sm:bg-transparent border-b sm:border-b-0"
                role="cell"
              >
                <strong class="text-primary-foreground sm:text-foreground text-sm sm:text-base uppercase sm:normal-case tracking-wide sm:tracking-normal text-pretty">
                  {item.name}
                </strong>
              </div>
              <div
                class="flex-1 px-5 py-4 sm:border-l border-border text-muted-foreground text-sm leading-relaxed text-pretty"
                role="cell"
              >
                {item.description}
                {resolved && (
                  <>
                    {" "}
                    <a
                      href={resolved.href}
                      target={resolved.openInNewTab ? "_blank" : undefined}
                      rel={resolved.openInNewTab || resolved.isExternal ? "noopener noreferrer" : undefined}
                      class="inline-flex items-center gap-1 font-semibold text-primary underline decoration-2 decoration-primary/50 underline-offset-2 hover:decoration-primary hover:bg-primary/10 px-2 py-1 rounded-sm transition-colors whitespace-nowrap"
                    >
                      {item.cta!.label}
                      {resolved.isExternal ? (
                        <ExternalLink class="w-3.5 h-3.5" aria-hidden="true" />
                      ) : (
                        <ArrowRight class="w-3.5 h-3.5" aria-hidden="true" />
                      )}
                      {resolved.openInNewTab && <span class="sr-only">(abre em nova aba)</span>}
                    </a>
                  </>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )
}
