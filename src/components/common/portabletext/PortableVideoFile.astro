---
import { urlFor } from "@/lib/sanity-client";
import type { SanityImageBase } from "@/lib/sanity-derived-types";

interface Props {
  node: {
    file?: {
      url: string;
      mimeType?: string;
    };
    posterImage?: SanityImageBase;
    caption?: string;
  };
}

const { node } = Astro.props;
const videoUrl = node.file?.url;
const videoMimeType = node.file?.mimeType?.trim() || "video/mp4";
const posterUrl = node.posterImage
  ? urlFor(node.posterImage).width(1280).height(720).fit("crop").crop("focalpoint").auto("format").quality(80).url()
  : undefined;
---

{
  videoUrl && (
    <figure class="my-8 not-prose">
      <div class="aspect-video rounded-xl overflow-hidden shadow-md bg-zinc-900">
        <video
          data-video-reload-fix
          poster={posterUrl}
          controls
          preload="metadata"
          playsinline
          class="w-full h-full object-contain"
          aria-label={node.caption || "Vídeo"}
        >
          <source src={videoUrl} type={videoMimeType} />
          Seu navegador não suporta reprodução de vídeo.
        </video>
      </div>

      {node.caption && <figcaption class="text-sm text-center text-zinc-500 mt-2 italic">{node.caption}</figcaption>}
    </figure>
  )
}
