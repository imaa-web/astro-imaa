---
import { ExternalLink, Paperclip } from "@lucide/astro";

interface Props {
  node: {
    label?: string;
    title?: string;
    url?: string;
  };
}

const { node } = Astro.props;

const fileUrl = node.url && /^https?:\/\//i.test(node.url) ? node.url : null;

if (node.url && !fileUrl) {
  console.warn("[PortableDownloadableFile] URL inválida ou insegura bloqueada.");
}
---

{
  fileUrl && (
    <div class="not-prose my-6 flex justify-center">
      <a
        href={fileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-4 py-3 w-fit max-w-md bg-muted hover:bg-muted/70 transition-colors rounded-lg border border-border group"
      >
        <Paperclip class="w-5 h-5 text-accent shrink-0" />
        <div class="flex flex-col min-w-0">
          {node.label && <span class="text-xs font-semibold uppercase tracking-wide text-accent">{node.label}</span>}
          <span class="text-sm font-medium text-foreground truncate">{node.title || "Visualizar Documento"}</span>
        </div>

        <ExternalLink class="w-4 h-4 text-muted-foreground ml-auto shrink-0 group-hover:text-accent transition-colors" />

        <span class="sr-only">(abre em nova aba)</span>
      </a>
    </div>
  )
}
