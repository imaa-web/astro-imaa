---
interface Props {
  node: {
    label?: string;
    title?: string;
    url?: string;
  };
}

const { node } = Astro.props;

const fileUrl = node.url && /^https?:\/\//i.test(node.url) ? node.url : null;

if (node.url && !fileUrl) {
  console.warn("[PortableDownloadableFile] URL inválida ou insegura bloqueada.");
}
---

{
  fileUrl && (
    <div class="not-prose my-6">
      <a
        href={fileUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-3 bg-zinc-100 hover:bg-zinc-200 transition-colors rounded-lg border border-zinc-200"
      >
        <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"
          />
        </svg>

        <div class="flex flex-col">
          {node.label && <span class="text-xs font-semibold uppercase text-zinc-500">{node.label}</span>}
          <span class="text-sm font-medium text-zinc-900">{node.title || "Visualizar Documento"}</span>
        </div>

        {/* Ícone indicando link externo/nova aba (Opcional, mas boa prática de UX) */}
        <svg class="w-4 h-4 text-zinc-400 ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
          />
        </svg>

        <span class="sr-only">(abre em nova aba)</span>
      </a>
    </div>
  )
}
