---
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"callToAction">;

const { title, description, link, buttonLabel } = Astro.props;
const isExternal = link?.startsWith("http");
---

{
  (title || description || link) && (
    <section class="py-16 px-4 bg-zinc-50">
      <div class="max-w-4xl mx-auto text-center">
        {title && <h2 class="text-3xl font-bold mb-4">{title}</h2>}
        {description && <p class="text-lg text-zinc-600 mb-8">{description}</p>}

        {link && (
          <a
            href={link}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noopener noreferrer" : undefined}
            class="inline-block bg-primary text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
          >
            {buttonLabel || "Saiba mais"}
          </a>
        )}
      </div>
    </section>
  )
}
