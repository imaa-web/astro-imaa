---
import Container from "@/components/layout/Container.astro";
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";
import { extractYouTubeId } from "@/lib/utils/video-utils";
import { AspectRatio } from "@/components/ui/aspect-ratio";

type Props = PageBuilderBlockOf<"youtubeEmbed">;

const { url, caption } = Astro.props;

const videoId = url ? extractYouTubeId(url) : null;
---

{
  videoId && (
    <Container size="md" class="py-pagebuilder">
      <AspectRatio ratio={16 / 9} className="relative overflow-hidden rounded-2xl bg-zinc-900 shadow-lg">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${videoId}`}
          title={caption ?? "Vídeo do YouTube"}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
          class="absolute inset-0 h-full w-full"
          loading="lazy"
        />
      </AspectRatio>
      {caption && <p class="text-sm text-muted-foreground font-sans text-center mt-3">{caption}</p>}
    </Container>
  )
}
