---
import SanityImage from "@/components/common/SanityImage.tsx";

import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"gallery">;

const { title, images } = Astro.props;
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    {title && <h2 class="text-2xl font-bold mb-8 text-center">{title}</h2>}

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {
        images?.map(
          (img) =>
            img?.asset && (
              <div class="aspect-square overflow-hidden rounded-lg">
                <SanityImage
                  client:visible
                  image={img}
                  className="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  sizes="(max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
                />
              </div>
            ),
        )
      }
    </div>
  </div>
</section>
