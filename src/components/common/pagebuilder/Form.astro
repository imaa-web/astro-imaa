---
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"form">;

const { title, formType, description, submitLabel } = Astro.props;
const inputClasses = "w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent";
---

<section class="py-16 px-4">
  <div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-lg p-8">
      {title && <h2 class="text-2xl font-bold mb-2 text-center">{title}</h2>}
      {description && <p class="text-zinc-600 mb-8 text-center">{description}</p>}

      <form class="space-y-6" data-form-type={formType} id="page-form">
        {
          (!formType || formType === "contact") && (
            <>
              <div>
                <label for="name" class="block text-sm font-medium mb-2">
                  Nome
                </label>
                <input type="text" id="name" name="name" required class={inputClasses} />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-2">
                  Email
                </label>
                <input type="email" id="email" name="email" required class={inputClasses} />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-2">
                  Mensagem
                </label>
                <textarea id="message" name="message" rows={4} required class={inputClasses} />
              </div>
            </>
          )
        }

        {
          formType === "application" && (
            <>
              <div>
                <label for="name-app" class="block text-sm font-medium mb-2">
                  Nome Completo
                </label>
                <input type="text" id="name-app" name="name" required class={inputClasses} />
              </div>
              <div>
                <label for="email-app" class="block text-sm font-medium mb-2">
                  Email
                </label>
                <input type="email" id="email-app" name="email" required class={inputClasses} />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium mb-2">
                  Telefone
                </label>
                <input type="tel" id="phone" name="phone" class={inputClasses} />
              </div>
            </>
          )
        }

        <button
          type="submit"
          class="w-full bg-primary text-white py-3 px-6 rounded-lg font-semibold hover:bg-primary/90 transition-colors"
        >
          {submitLabel || "Enviar"}
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("page-form");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form as HTMLFormElement);
    // Handle submission to your API endpoint
  });
</script>
