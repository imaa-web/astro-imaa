---
import Container from "@/components/layout/Container.astro";
import { urlFor } from "@/lib/sanity-client";
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"videoFile">;

const { file, posterImage, caption, autoplay = false } = Astro.props;

const videoUrl = file?.url ?? null;
const posterUrl = posterImage?.asset
  ? urlFor(posterImage).width(1280).height(720).fit("crop").crop("focalpoint").auto("format").url()
  : null;
---

{
  videoUrl && (
    <Container size="md" class="py-pagebuilder">
      <div class="relative rounded-2xl overflow-hidden shadow-lg aspect-video bg-black">
        <video
          src={videoUrl}
          class="w-full h-full object-contain"
          controls={!autoplay}
          autoplay={autoplay}
          muted={autoplay}
          loop={autoplay}
          playsinline
          preload={autoplay ? "auto" : "metadata"}
          poster={!autoplay && posterUrl ? posterUrl : undefined}
          aria-label={autoplay ? caption || "Background video" : undefined}
        />
      </div>
      {caption && <p class="text-sm text-muted-foreground font-sans text-center mt-3">{caption}</p>}
    </Container>
  )
}
