---
import SanityImage from "@/components/common/SanityImage.tsx";

import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"hero">;

const { heading, tagline, image } = Astro.props;
---

<section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
  {
    image?.asset && (
      <div class="absolute inset-0 z-0">
        <SanityImage client:load image={image} className="w-full h-full object-cover" sizes="100vw" loading="eager" />
      </div>
    )
  }

  <div class="relative z-10 text-center px-4 max-w-4xl">
    {heading && <h1 class="text-4xl md:text-6xl font-bold mb-4">{heading}</h1>}
    {tagline && <p class="text-xl md:text-2xl opacity-90">{tagline}</p>}
  </div>
</section>
