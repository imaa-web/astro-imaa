---
import Container from "@/components/layout/Container.astro";
import { buttonVariants } from "@/components/ui/button";
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";
import { resolveCta } from "@/lib/utils/link-utils";
import { cn } from "@/lib/utils/ui-utils";
import { ArrowRight, ExternalLink } from "@lucide/astro";

type Props = PageBuilderBlockOf<"ctaSection">;

const { heading, subheading, primaryCta, secondaryCta, background = "primary" } = Astro.props;

const isPrimary = background === "primary";

const resolvedPrimary = primaryCta?.label ? resolveCta(primaryCta) : null;
const resolvedSecondary = secondaryCta?.label ? resolveCta(secondaryCta) : null;
---

<section
  class={cn(
    "my-pagebuilder py-16 md:py-24",
    isPrimary ? "bg-primary text-primary-foreground" : "bg-muted text-foreground",
  )}
>
  <Container size="md" class="text-center">
    <h2 class={cn("heading-2 mb-4", isPrimary && "text-primary-foreground")}>{heading}</h2>
    {
      subheading && (
        <p class={cn("mb-10 max-w-xl mx-auto", isPrimary ? "caption-text-primary-foreground" : "body-text")}>
          {subheading}
        </p>
      )
    }

    {
      (resolvedPrimary || resolvedSecondary) && (
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {resolvedPrimary && (
            <a
              href={resolvedPrimary.href}
              target={resolvedPrimary.openInNewTab ? "_blank" : undefined}
              rel={resolvedPrimary.openInNewTab ? "noopener noreferrer" : undefined}
              class={cn(
                buttonVariants({ size: "lg" }),
                isPrimary
                  ? "bg-white text-primary hover:bg-white/90"
                  : "bg-primary text-primary-foreground hover:bg-primary/90",
              )}
            >
              {primaryCta!.label}
              {resolvedPrimary.openInNewTab && <span class="sr-only">(abre em nova aba)</span>}
              {resolvedPrimary.isExternal ? (
                <ExternalLink class="w-4 h-4" aria-hidden="true" />
              ) : (
                <ArrowRight class="w-4 h-4" aria-hidden="true" />
              )}
            </a>
          )}
          {resolvedSecondary && (
            <a
              href={resolvedSecondary.href}
              target={resolvedSecondary.openInNewTab ? "_blank" : undefined}
              rel={resolvedSecondary.openInNewTab ? "noopener noreferrer" : undefined}
              class={cn(
                buttonVariants({ variant: "outline", size: "lg" }),
                isPrimary
                  ? "border-white/40 text-white hover:bg-white/10 hover:border-white/70 bg-transparent"
                  : "border-primary/40 text-primary hover:bg-primary/10",
              )}
            >
              {secondaryCta!.label}
              {resolvedSecondary.openInNewTab && <span class="sr-only">(abre em nova aba)</span>}
              {resolvedSecondary.isExternal ? (
                <ExternalLink class="w-4 h-4" aria-hidden="true" />
              ) : (
                <ArrowRight class="w-4 h-4" aria-hidden="true" />
              )}
            </a>
          )}
        </div>
      )
    }
  </Container>
</section>
