---
import { urlFor } from "@/lib/sanity-client";
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"downloadableFile">;

const { asset, title, label } = Astro.props;
const fileUrl = asset ? urlFor(asset).url() : undefined;
---

{
  fileUrl && (
    <div class="my-8 px-4">
      <a
        href={fileUrl}
        download
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-800 text-white rounded-lg hover:bg-zinc-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          />
        </svg>
        {label || title || "Baixar arquivo"}
      </a>
    </div>
  )
}
