---
import CtaSection from "@/components/common/pagebuilder/CtaSection.astro";
import Gallery from "@/components/common/pagebuilder/gallery/Gallery";
import RichText from "@/components/common/pagebuilder/RichText.astro";
import TextWithIllustration from "@/components/common/pagebuilder/TextWithIllustration.astro";
import VideoFile from "@/components/common/pagebuilder/VideoFile.astro";
import YoutubeEmbed from "@/components/common/pagebuilder/YoutubeEmbed.astro";
import type { PageBuilder } from "@/lib/sanity-derived-types";

interface Props {
  pageBuilder?: PageBuilder;
}

const { pageBuilder } = Astro.props;
---

{
  pageBuilder?.map((block) => {
    switch (block._type) {
      case "richText":
        return <RichText {...block} />;
      case "textWithIllustration":
        return <TextWithIllustration {...block} />;
      case "ctaSection":
        return <CtaSection {...block} />;
      case "gallery":
        return <Gallery {...block} client:visible />;
      case "videoFile":
        return <VideoFile {...block} />;
      case "youtubeEmbed":
        return <YoutubeEmbed {...block} />;
      case "horizontalRule":
        return <hr class="mx-auto border-border" />;
      default:
        if (import.meta.env.DEV) {
          console.warn(`Unknown pageBuilder block type: ${(block as { _type: string })._type}`);
        }
        return null;
    }
  })
}
