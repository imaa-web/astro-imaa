---
import SanityImage from "@/components/common/SanityImage.tsx";

import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"textWithIllustration">;

const { heading, tagline, excerpt, image } = Astro.props;
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1">
        {heading && <h2 class="text-3xl font-bold mb-4">{heading}</h2>}
        {tagline && <p class="text-lg text-zinc-600 mb-4">{tagline}</p>}
        {excerpt && <p class="text-zinc-700">{excerpt}</p>}
      </div>

      <div class="order-1 md:order-2">
        {
          image?.asset && (
            <SanityImage
              client:load
              image={image}
              className="rounded-xl shadow-lg w-full h-auto"
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          )
        }
      </div>
    </div>
  </div>
</section>
