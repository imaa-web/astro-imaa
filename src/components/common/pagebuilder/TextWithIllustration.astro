---
import SanityImage from "@/components/common/SanityImage";
import Container from "@/components/layout/Container.astro";
import type { PageBuilderBlockOf } from "@/lib/sanity-derived-types";

type Props = PageBuilderBlockOf<"textWithIllustration">;

const { heading, text, image, imagePosition = "right" } = Astro.props;
const isImageLeft = imagePosition === "left";
---

<Container size="xl" class="py-pagebuilder">
  <div class={`flex flex-col ${isImageLeft ? "lg:flex-row-reverse" : "lg:flex-row"} gap-12 items-center`}>
    <div class="flex-1 min-w-0">
      {heading && <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-6">{heading}</h2>}
      {text && <p class="text-muted-foreground font-sans leading-relaxed text-base">{text}</p>}
    </div>

    {
      image?.asset && (
        <div class="w-full lg:w-[45%] shrink-0">
          <div class="rounded-2xl overflow-hidden shadow-lg aspect-4/3">
            <SanityImage
              client:visible
              image={image}
              width={800}
              height={600}
              sizes="(max-width: 1024px) 100vw, 45vw"
              className="w-full h-full object-cover"
            />
          </div>
        </div>
      )
    }
  </div>
</Container>
