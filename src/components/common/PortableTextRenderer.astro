---
import PortableDownloadableFile from "@/components/common/portabletext/PortableDownloadableFile.astro";
import PortableHR from "@/components/common/portabletext/PortableHR.astro";
import PortableImage from "@/components/common/portabletext/PortableImage.astro";
import PortableLink from "@/components/common/portabletext/PortableLink.astro";
import PortableVideoFile from "@/components/common/portabletext/PortableVideoFile.astro";
import PortableYoutubeEmbed from "@/components/common/portabletext/PortableYoutubeEmbed.astro";
import { PortableText } from "astro-portabletext";
import type { PortableTextProps } from "astro-portabletext/types";

interface Props {
  value?: PortableTextProps["value"] | null;
}

const { value } = Astro.props;

const components = {
  type: {
    downloadableFile: PortableDownloadableFile,
    horizontalRule: PortableHR,
    image: PortableImage,
    videoFile: PortableVideoFile,
    youtubeEmbed: PortableYoutubeEmbed,
  },
  mark: {
    link: PortableLink,
  },
};
---

{
  value && (
    <article class="prose prose-zinc prose-p:text-[16px] max-w-none">
      <PortableText value={value} components={components} />
    </article>
  )
}
