---
import Navbar from "@/components/layout/navigation/Navbar";
import type { QueryMenuItem, QuerySocialLink } from "@/lib/sanity-derived-types";
import type { SITE_SETTINGS_QUERY_RESULT } from "@/lib/sanity.types";

interface Props {
  siteSettings: SITE_SETTINGS_QUERY_RESULT;
}

const { siteSettings } = Astro.props;

const mainMenu = siteSettings?.mainMenu || { label: "", items: [] };

const menuItems: QueryMenuItem[] = (mainMenu.items ?? []).map((item) => ({
  ...item,
  submenu: item.submenu ?? null,
}));

const VALID_PLATFORMS = ["bluesky", "facebook", "instagram", "twitter", "youtube"] as const;

const socialLinks: QuerySocialLink[] = (siteSettings?.socialLinks ?? []).filter((link): link is QuerySocialLink =>
  VALID_PLATFORMS.includes(link.platform as (typeof VALID_PLATFORMS)[number]),
);

const currentPath = Astro.url.pathname;
---

<Navbar
  client:load
  currentPath={currentPath}
  menuItems={menuItems}
  socialLinks={socialLinks}
  logo={siteSettings?.logo}
/>
