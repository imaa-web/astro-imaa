---
import Navbar from "@/components/layout/navigation/Navbar";
import type {
  QueryMenuItems,
  QuerySocialLinks,
  SanityImageBase,
} from "@/lib/sanity-derived-types";
import { normalizeMenuItems } from "@/lib/utils/link-utils";

interface Props {
  logo?: SanityImageBase | null;
  menuItems?: QueryMenuItems | null;
  socialLinks?: QuerySocialLinks | null;
}

const { logo = null, menuItems = [], socialLinks = [] } = Astro.props;

const normalizedMenuItems = normalizeMenuItems(menuItems);

const currentPath = Astro.url.pathname;
---

<Navbar
  client:load
  currentPath={currentPath}
  menuItems={normalizedMenuItems}
  socialLinks={socialLinks ?? []}
  logo={logo}
/>
