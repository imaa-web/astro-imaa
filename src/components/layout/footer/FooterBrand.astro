---
import blocoLogo from "@/assets/bloco.jpg";
import SocialLinks from "@/components/common/SocialLinks";
import type { QuerySocialLink } from "@/lib/sanity-derived-types";
import { Image } from "astro:assets";

interface Props {
  description?: string | null;
  socialLinks: QuerySocialLink[];
}

const { description, socialLinks } = Astro.props;
---

<div>
  <a href="/" class="flex items-center gap-3 mb-4 w-fit">
    <Image
      src={blocoLogo}
      width={48}
      height={48}
      class="w-12 h-12 rounded-full object-cover"
      alt="Logo Instituto Maestro Abiud Almeida"
    />
    <div>
      <p class="text-xs font-semibold text-secondary uppercase tracking-wide font-sans">Instituto Maestro</p>
      <p class="text-xl font-bold text-white font-serif leading-tight">Abiud Almeida</p>
    </div>
  </a>

  {
    description && (
      <p class="text-sm text-primary-foreground/80 leading-relaxed font-sans max-w-sm mb-6">{description}</p>
    )
  }

  <SocialLinks
    client:visible
    socialLinks={socialLinks}
    className="gap-3"
    iconClassName="w-5 h-5 text-white"
    linkClassName="size-10"
  />
</div>
