---
import DocumentItem from "@/components/common/DocumentItem.astro";
import TransparencyProjectStatusBadge from "@/components/features/transparency/TransparencyProjectStatusBadge";
import type { TransparencyProject } from "@/lib/sanity-derived-types";

interface Props {
  projects: TransparencyProject[];
}

const { projects } = Astro.props;
---

<div>
  <h2 class="heading-2 mb-6">Projetos em Andamento</h2>
  <div class="space-y-6">
    {
      projects.map((project) => {
        const validDocs = project.documents?.filter((doc) => doc.fileUrl) ?? [];
        return (
          <div class="rounded-2xl border border-border overflow-hidden shadow-sm">
            <div class="px-6 py-4 bg-muted flex flex-col lg:flex-row lg:items-center justify-between gap-3">
              <div class="min-w-0 flex-1">
                <h3 class="heading-3">{project.title}</h3>
                {project.origin && <p class="caption-text mt-0.5">{project.origin}</p>}
              </div>
              <div class="flex flex-wrap items-center gap-3">
                {project.value && <span class="text-sm font-bold text-primary font-sans">{project.value}</span>}
                <TransparencyProjectStatusBadge status={project.status} client:load />
              </div>
            </div>

            {validDocs.length > 0 && (
              <div class="px-6 py-4 divide-y divide-border">
                {validDocs.map((doc) => (
                  <DocumentItem doc={doc} wrapperClass="flex items-center justify-between gap-4 py-3" />
                ))}
              </div>
            )}
          </div>
        );
      })
    }
  </div>
</div>
