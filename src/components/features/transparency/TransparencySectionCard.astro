---
import type { ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT } from "@/lib/sanity.types";
import { ArrowRight, FileText } from "@lucide/astro";

type Section = NonNullable<ALL_TRANSPARENCY_SECTIONS_QUERY_RESULT>[number];

interface Props {
  section: Section;
}

const { section } = Astro.props;
---

{
  section.slug && (
    <a
      href={`/transparencia/${section.slug}`}
      class="group flex flex-col gap-3 p-6 rounded-2xl border border-border bg-card hover:border-primary hover:shadow-md transition-all duration-200"
    >
      <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center shrink-0 group-hover:bg-accent transition-colors">
          <FileText class="w-6 h-6 text-white" />
        </div>
        <div>
          {section.partner && (
            <p class="text-xs font-semibold text-accent uppercase tracking-widest font-sans">Parceiro</p>
          )}
          <h2 class="font-bold text-foreground leading-tight">{section.partner ?? section.title ?? "Seção"}</h2>
        </div>
      </div>
      {section.excerpt && (
        <p class="text-sm text-muted-foreground font-sans leading-relaxed line-clamp-2">{section.excerpt}</p>
      )}
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary font-sans mt-auto group-hover:underline">
        Ver documentos <ArrowRight class="w-4 h-4" />
      </span>
    </a>
  )
}
