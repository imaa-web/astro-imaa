---
import Head from "@/components/common/Head.astro";
import Footer from "@/components/layout/footer/Footer.astro";
import Header from "@/components/layout/Header.astro";
import type { SanityImageBase } from "@/lib/sanity-derived-types";
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: SanityImageBase | null;
}

const { title, description, canonical, image } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <Head title={title} description={description} canonical={canonical} image={image} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ClientRouter />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
