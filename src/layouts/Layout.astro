---
import Head from "@/components/common/Head.astro";
import Footer from "@/components/layout/footer/Footer.astro";
import Header from "@/components/layout/Header.astro";
import BackToTopButton from "@/components/ui/BackToTopButton.astro";
import { fetchSiteSettings } from "@/lib/fetch-site-settings";
import type { SanityImageBase } from "@/lib/sanity-derived-types";
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: SanityImageBase | null;
}

let siteSettings;
try {
  siteSettings = await fetchSiteSettings();
} catch (error) {
  console.error("Failed to fetch site settings:", error);
  return new Response("Service temporarily unavailable", { status: 503 });
}

const { title, description, canonical, image } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <Head title={title} description={description} canonical={canonical} image={image} siteSettings={siteSettings} />
    <link rel="sitemap" href="/sitemap.xml" />
    <ClientRouter />
  </head>
  <body>
    <Header siteSettings={siteSettings} />
    <main><slot /></main>
    <Footer siteSettings={siteSettings} />
    <BackToTopButton />
  </body>
</html>
