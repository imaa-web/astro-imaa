---
import Head from "@/components/common/Head.astro";
import Footer from "@/components/layout/footer/Footer.astro";
import Header from "@/components/layout/Header.astro";
import BackToTopButton from "@/components/ui/BackToTopButton.astro";
import type { SanityImageBase, SeoSettings } from "@/lib/sanity-derived-types";
import "@/styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: SanityImageBase | null;
  noIndex?: boolean;
}

const { siteSettings } = Astro.locals;

if (!siteSettings) {
  return new Response("Site settings unavailable", { status: 503 });
}

const { title, description, canonical, image, noIndex } = Astro.props;
const isPreview = import.meta.env.PUBLIC_DEPLOY_MODE === "preview";
const seoSettings: SeoSettings = {
  defaultSeoDescription: siteSettings.defaultSeoDescription,
  logo: siteSettings.logo,
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <Head
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      seoSettings={seoSettings}
      noIndex={isPreview || noIndex}
    />
    <ClientRouter />
    <Font cssVariable="--font-inter" />
    <Font cssVariable="--font-merriweather" />
    <Font cssVariable="--font-work-sans" />
  </head>
  <body>
    <Header
      logo={siteSettings.logo}
      menuItems={siteSettings.mainMenu?.items ?? []}
      socialLinks={siteSettings.socialLinks ?? []}
    />
    <main id="main-content"><slot /></main>
    <Footer
      siteTitle={siteSettings.title}
      menuLabel={siteSettings.footerMenu?.label ?? null}
      menuItems={siteSettings.footerMenu?.items ?? []}
      description={siteSettings.defaultSeoDescription}
      socialLinks={siteSettings.socialLinks ?? []}
      contactInfo={siteSettings.contactInfo ?? null}
      logo={siteSettings.logo}
    />
    <BackToTopButton />
  </body>
</html>
